{
  "manifest_version": 3,
  "name": "Cookie Helper: Consent Guard",
  "version": "1.0",
  "description": "Detects cookie-consent banners, explains cookies, and lets you block selected ones.",
  "permissions": [
    "cookies",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Cookie Helper"
  }
}
